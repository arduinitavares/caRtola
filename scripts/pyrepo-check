#!/usr/bin/env python3
from __future__ import annotations

import argparse
import subprocess
import sys
from collections.abc import Sequence
from dataclasses import dataclass


@dataclass(frozen=True)
class Check:
    name: str
    command: tuple[str, ...]


CHECKS: tuple[Check, ...] = (
    Check(
        "ruff",
        (
            sys.executable,
            "-m",
            "ruff",
            "check",
            "src/cartola",
            "src/tests",
            "scripts",
        ),
    ),
    Check("ty", (sys.executable, "-m", "ty", "check")),
    Check(
        "bandit",
        (
            sys.executable,
            "-m",
            "bandit",
            "-c",
            "pyproject.toml",
            "-r",
            "src/cartola",
        ),
    ),
    Check("pytest", (sys.executable, "-m", "pytest")),
)


def parse_args(argv: Sequence[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run repository Python quality checks.")
    parser.add_argument("--all", action="store_true", help="Run all checks.")
    parser.add_argument(
        "checks",
        nargs="*",
        help="Optional subset of checks to run.",
    )
    return parser.parse_args(argv)


def selected_checks(args: argparse.Namespace) -> tuple[Check, ...]:
    if args.all or not args.checks:
        return CHECKS
    available = {check.name for check in CHECKS}
    unknown = sorted(set(args.checks) - available)
    if unknown:
        names = ", ".join(unknown)
        raise ValueError(f"Unknown check(s): {names}")
    requested = set(args.checks)
    return tuple(check for check in CHECKS if check.name in requested)


def run_check(check: Check) -> int:
    command = " ".join(check.command)
    print(f"\n==> {check.name}: {command}", flush=True)
    return subprocess.run(check.command, check=False).returncode


def main(argv: Sequence[str] | None = None) -> int:
    args = parse_args(argv)
    try:
        checks = selected_checks(args)
    except ValueError as error:
        print(error, file=sys.stderr)
        return 2

    for check in checks:
        return_code = run_check(check)
        if return_code != 0:
            return return_code
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
